{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 390,
          "height": 844,
          "deviceScaleFactor": 3
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:best-practices": ["error", { "minScore": 0.85 }]
      }
    }
  }
}
