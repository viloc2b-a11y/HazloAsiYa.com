{
  "organization": {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "HazloAsíYa",
    "url": "https://www.hazloasiya.com",
    "description": "Plataforma en español para ayudar a familias hispanas en EE. UU. a completar trámites sin errores.",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "availableLanguage": "Spanish"
    }
  },
  "website": {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "HazloAsíYa",
    "url": "https://www.hazloasiya.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.hazloasiya.com/?s={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  "faq": {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cómo funciona HazloAsíYa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Completas un cuestionario gratis en 5 minutos. Te decimos qué tienes, qué te falta y cómo completar tu trámite paso a paso."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El cuestionario es gratis. El plan básico cuesta $19 por trámite y el plan anual $49 para acceso ilimitado."
        }
      },
      {
        "@type": "Question",
        "name": "¿Es asesoría legal?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. HazloAsíYa es una guía informativa. No somos abogados ni representantes legales."
        }
      },
      {
        "@type": "Question",
        "name": "¿Mis datos están seguros?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Usamos SSL, pagos seguros con Square y no guardamos información de tarjetas."
        }
      },
      {
        "@type": "Question",
        "name": "¿Tienen garantía?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, ofrecemos garantía de satisfacción de 30 días."
        }
      }
    ]
  },
