# Next.js (build-time / public)
NEXT_PUBLIC_APP_URL=https://hazloasiya.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# GA4 — solo carga tras consent (Consent Mode v2 en layout)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# A/B test del upsell de revisión express (copy CTA A vs B)
# Dejar en false hasta tener tráfico suficiente (orientativo: 200–300+ quiz completados).
# En true: asignación 50/50 en localStorage haz_ab_upsell-copy-v1. Se puede cambiar solo en
# Cloudflare Pages → Environment Variables sin redeploy obligatorio.
NEXT_PUBLIC_AB_UPSELL_ACTIVE=false

# Cloudflare Pages Functions — set in dashboard or wrangler secrets
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Módulo 12 — newsletter (Cloudflare Pages Functions: subscribe-email)
EMAIL_PROVIDER=convertkit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
# BREVO_API_KEY=
# BREVO_LIST_ID=

# Módulo 12 — afiliados (público; rellenar antes de producción)
NEXT_PUBLIC_AFFILIATE_BANCO_ITIN=
NEXT_PUBLIC_AFFILIATE_REMESAS=
NEXT_PUBLIC_AFFILIATE_PREPAGO=
