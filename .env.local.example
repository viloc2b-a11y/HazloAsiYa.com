# Next.js (build-time / public)
NEXT_PUBLIC_APP_URL=https://www.hazloasiya.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Google Analytics 4 (Consent Mode v2)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mailchimp (server-only; Next route + Cloudflare Functions)
MAILCHIMP_API_KEY=your-mailchimp-api-key-here
MAILCHIMP_AUDIENCE_ID=your-audience-id
# Opcional si el API key ya termina en -usXX (datacenter)
MAILCHIMP_SERVER=

# Square (server-only + public ids/links)
SQUARE_ACCESS_TOKEN=your-square-token
SQUARE_LOCATION_ID=your-location-id
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id

# Square Payment Links (public)
NEXT_PUBLIC_SQUARE_LINK_REVISION_EXPRESS=https://square.link/...
NEXT_PUBLIC_SQUARE_LINK_KIT_SNAP=https://square.link/...
NEXT_PUBLIC_SQUARE_LINK_KIT_ITIN=https://square.link/...

# Hub de PDFs (/pdf): en true omite el muro de pago en el navegador (solo pruebas locales).
# NEXT_PUBLIC_PDF_SKIP_PAYWALL=true

# A/B test del upsell (apagado por defecto)
NEXT_PUBLIC_AB_UPSELL_ACTIVE=false

# Meta Pixel (opcional; vacío hasta tener ID)
NEXT_PUBLIC_META_PIXEL_ID=

# HazloAsíYa usa el SDK `openai`: primero Responses API (`responses.create`), si falla Chat Completions.
# Clave: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Ej.: gpt-4.1-mini, gpt-5.3 (si tu proyecto tiene acceso al modelo)
OPENAI_MODEL=gpt-4.1-mini
# false o 0 = solo Chat Completions (sin Responses)
# OPENAI_USE_RESPONSES_API=true
# scripts/monitor-regulations.ts con --with-ai también usa OPENAI_API_KEY
SQUARE_WEBHOOK_SIGNATURE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Afiliados (público)
NEXT_PUBLIC_AFFILIATE_BANCO_ITIN=
NEXT_PUBLIC_AFFILIATE_REMESAS=
NEXT_PUBLIC_AFFILIATE_PREPAGO=
